From 99e9f289f90aa112ff0c3244474a3b79d6928819 Mon Sep 17 00:00:00 2001
From: Josh Law <joshlaw48@gmail.com>
Date: Sat, 11 Apr 2026 20:21:56 +0000
Subject: [PATCH 1/2] lib/ts_fsm: Fix text search evasion on block boundaries

When a partial match crossed a block boundary and subsequently failed
midway through the second block, the FSM algorithm failed to properly
rewind the 'consumed' byte count. This caused it to skip the remaining
data in the first block, potentially blinding IDS systems to overlapping
attack patterns.

This patch updates the TOKEN_MISMATCH logic to correctly resume the
search at match_start + 1, ensuring no data is skipped even when
fragmented across blocks.

Signed-off-by: Josh Law <joshlaw48@gmail.com>
---
 lib/ts_fsm.c | 8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

diff --git a/lib/ts_fsm.c b/lib/ts_fsm.c
index 053615f4fcd7..8450e6316fa4 100644
--- a/lib/ts_fsm.c
+++ b/lib/ts_fsm.c
@@ -148,7 +148,13 @@ static unsigned int fsm_find(struct ts_config *conf, struct ts_state *state)
 	do {				\
 		if (strict)		\
 			goto no_match;	\
-		block_idx++;		\
+		if (match_start < consumed) { \
+			consumed = match_start + 1; \
+			block_idx = 0; \
+			block_len = conf->get_next_block(consumed, &data, conf, state); \
+		} else { \
+			block_idx = match_start - consumed + 1; \
+		} \
 		goto startover;		\
 	} while(0)
 
