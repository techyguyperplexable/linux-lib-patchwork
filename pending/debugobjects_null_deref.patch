From 3a8fa199e581ab768d95731697ffb947b51e5845 Mon Sep 17 00:00:00 2001
From: Josh Law <joshlaw48@gmail.com>
Date: Sun, 12 Apr 2026 00:11:11 +0000
Subject: [PATCH] debugobjects: fix NULL obj_cache dereference in
 kmem_alloc_batch()

kmem_alloc_batch() calls free_object_list() on partial allocation
failure, but free_object_list() uses the global obj_cache which is
NULL when called from debug_objects_replace_static_objects() during
early boot. Use the local @cache parameter for cleanup instead.

Fixes: aebbfe0779b2 ("debugobjects: Prepare kmem_cache allocations for batching")
Cc: stable@vger.kernel.org
Signed-off-by: Josh Law <joshlaw48@gmail.com>
---
 lib/debugobjects.c | 10 +++++++++-
 1 file changed, 9 insertions(+), 1 deletion(-)

diff --git a/lib/debugobjects.c b/lib/debugobjects.c
index 12e2e42e6a31..d9fd8913a469 100644
--- a/lib/debugobjects.c
+++ b/lib/debugobjects.c
@@ -370,7 +370,15 @@ static bool kmem_alloc_batch(struct hlist_head *head, struct kmem_cache *cache,
 	for (int cnt = 0; cnt < ODEBUG_BATCH_SIZE; cnt++) {
 		obj = kmem_cache_zalloc(cache, gfp);
 		if (!obj) {
-			free_object_list(head);
+			struct hlist_node *tmp;
+			struct debug_obj *o;
+
+			/* Use @cache, not obj_cache which may be unset */
+			hlist_for_each_entry_safe(o, tmp, head, node) {
+				hlist_del(&o->node);
+				kmem_cache_free(cache, o);
+			}
+			debug_objects_freed += cnt;
 			return false;
 		}
 		debug_objects_allocated++;
-- 
