From 1f196ceb63b1eb1692d5e3129a8d7c9e81be0494 Mon Sep 17 00:00:00 2001
From: Josh Law <objecting@objecting.org>
Date: Wed, 8 Apr 2026 21:40:26 +0000
Subject: [PATCH] lib/idr: fix memory leak on error path

If ida_alloc_range() is called with a pre-allocated bitmap and the
subsequent xas_store() fails, the bitmap is leaked. Fix this by
ensuring the cleanup path frees the bitmap on error, and add a
test case.

Signed-off-by: Josh Law <objecting@objecting.org>
---
 lib/idr.c      | 2 +-
 lib/test_ida.c | 4 ++++
 2 files changed, 5 insertions(+), 1 deletion(-)

diff --git a/lib/idr.c b/lib/idr.c
index ce28db18b284..28183b09ea7f 100644
--- a/lib/idr.c
+++ b/lib/idr.c
@@ -460,7 +460,7 @@ int ida_alloc_range(struct ida *ida, unsigned int min, unsigned int max,
 		bit = min % IDA_BITMAP_BITS;
 		goto retry;
 	}
-	if (bitmap != alloc)
+	if (bitmap != alloc || xas_error(&xas))
 		kfree(alloc);
 	if (xas_error(&xas))
 		return xas_error(&xas);
diff --git a/lib/test_ida.c b/lib/test_ida.c
index 51bb961bf666..5affeaaade5b 100644
--- a/lib/test_ida.c
+++ b/lib/test_ida.c
@@ -279,6 +279,10 @@ static void ida_check_leak(struct ida *ida)
 	id = ida_alloc_min(ida, 256, GFP_NOWAIT);
 	if (id >= 0)
 		ida_free(ida, id);
+
+	id = ida_alloc_min(ida, 1024, GFP_KERNEL);
+	if (id >= 0)
+		ida_free(ida, id);
 }
 
 static DEFINE_IDA(ida);
