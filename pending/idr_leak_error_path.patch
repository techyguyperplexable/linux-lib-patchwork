From 1f196ceb63b1eb1692d5e3129a8d7c9e81be0494 Mon Sep 17 00:00:00 2001
From: Josh Law <objecting@objecting.org>
Date: Wed, 8 Apr 2026 21:40:26 +0000
Subject: [PATCH] lib/idr: fix memory leak on error path

If ida_alloc_range() is called with a pre allocated bitmap and the
subsequent xas_store() fails, the bitmap is leaked, causing this splat:

unreferenced object 0x61d89400 (size 128):
  comm "swapper/0", pid 1, jiffies 4294937304
  hex dump (first 32 bytes):
    ff ff ff ff ff ff ff 7f 00 00 00 00 00 00 00 00 ................
    00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 ................
  backtrace (crc 724000d1):
    save_stack_trace+0x59/0x5e
    stack_trace_save+0x85/0x9d
    set_track_prepare+0x4c/0x6c
    __alloc_object+0x1ec/0x1f7
    __create_object+0x30/0x98
    kmemleak_alloc+0x34/0x37
    kmemleak_alloc_recursive.constprop.0+0x1f/0x22
    __kmalloc_cache_noprof+0x1ce/0x1f6
    kzalloc_noprof.constprop.0+0x77/0x7f
    ida_alloc_range+0x208/0x514
    ida_alloc_min.constprop.0+0x1c/0x1e
    ida_check_leaf.constprop.0+0x47/0x134
    ida_checks+0x233/0xebc
    do_one_initcall+0x1cc/0x400
    kernel_init_freeable+0x40c/0x4b3
    kernel_init+0x2d/0x1c0

Fix this by
ensuring the cleanup path frees the bitmap on error, and add a
test case.

Signed-off-by: Josh Law <objecting@objecting.org>
---
 lib/idr.c      | 2 +-
 lib/test_ida.c | 4 ++++
 2 files changed, 5 insertions(+), 1 deletion(-)

diff --git a/lib/idr.c b/lib/idr.c
index ce28db18b284..28183b09ea7f 100644
--- a/lib/idr.c
+++ b/lib/idr.c
@@ -460,7 +460,7 @@ int ida_alloc_range(struct ida *ida, unsigned int min, unsigned int max,
 		bit = min % IDA_BITMAP_BITS;
 		goto retry;
 	}
-	if (bitmap != alloc)
+	if (bitmap != alloc || xas_error(&xas))
 		kfree(alloc);
 	if (xas_error(&xas))
 		return xas_error(&xas);
diff --git a/lib/test_ida.c b/lib/test_ida.c
index 51bb961bf666..5affeaaade5b 100644
--- a/lib/test_ida.c
+++ b/lib/test_ida.c
@@ -279,6 +279,10 @@ static void ida_check_leak(struct ida *ida)
 	id = ida_alloc_min(ida, 256, GFP_NOWAIT);
 	if (id >= 0)
 		ida_free(ida, id);
+
+	id = ida_alloc_min(ida, 1024, GFP_KERNEL);
+	if (id >= 0)
+		ida_free(ida, id);
 }
 
 static DEFINE_IDA(ida);
