From cfdaeafdcdf4d6954c211843a60ef26a504adf28 Mon Sep 17 00:00:00 2001
From: Josh Law <objecting@objecting.org>
Date: Wed, 8 Apr 2026 21:39:44 +0000
Subject: [PATCH] lib/idr: fix memory leak on inline allocation

If ida_alloc_range() allocates a bitmap inline, it fails to update the
alloc pointer. If the subsequent xas_store() fails and retries, the
bitmap is leaked.

Fix this by setting alloc to the new bitmap, and add a test case.

Signed-off-by: Josh Law <objecting@objecting.org>
---
 lib/idr.c      |  4 +++-
 lib/test_ida.c | 10 ++++++++++
 2 files changed, 13 insertions(+), 1 deletion(-)

diff --git a/lib/idr.c b/lib/idr.c
index 1649f41016e7..ce28db18b284 100644
--- a/lib/idr.c
+++ b/lib/idr.c
@@ -443,8 +443,10 @@ int ida_alloc_range(struct ida *ida, unsigned int min, unsigned int max,
 			bitmap = xa_mk_value(1UL << bit);
 		} else {
 			bitmap = alloc;
-			if (!bitmap)
+			if (!bitmap) {
 				bitmap = kzalloc_obj(*bitmap, GFP_NOWAIT);
+				alloc = bitmap;
+			}
 			if (!bitmap)
 				goto alloc;
 			__set_bit(bit, bitmap->bitmap);
diff --git a/lib/test_ida.c b/lib/test_ida.c
index c400b24f88b6..51bb961bf666 100644
--- a/lib/test_ida.c
+++ b/lib/test_ida.c
@@ -272,6 +272,15 @@ static void ida_check_find_first(struct ida *ida)
 	IDA_BUG_ON(ida, !ida_is_empty(ida));
 }
 
+static void ida_check_leak(struct ida *ida)
+{
+	int id;
+
+	id = ida_alloc_min(ida, 256, GFP_NOWAIT);
+	if (id >= 0)
+		ida_free(ida, id);
+}
+
 static DEFINE_IDA(ida);
 
 static int ida_checks(void)
@@ -286,6 +295,7 @@ static int ida_checks(void)
 	ida_check_conv(&ida);
 	ida_check_bad_free(&ida);
 	ida_check_find_first(&ida);
+	ida_check_leak(&ida);
 
 	printk("IDA: %u of %u tests passed\n", tests_passed, tests_run);
 	return (tests_run != tests_passed) ? 0 : -EINVAL;
-- 
