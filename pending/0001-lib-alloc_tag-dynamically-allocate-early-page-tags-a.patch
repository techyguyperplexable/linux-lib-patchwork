From 99737df437e8fc2840446c04750a2482bfe9d8c1 Mon Sep 17 00:00:00 2001
From: Josh Law <joshlaw48@gmail.com>
Date: Sun, 12 Apr 2026 15:39:43 +0000
Subject: [PATCH] lib/alloc_tag: dynamically allocate early page tags array

The early page tagging array is currently hardcoded to 8192 elements.
If boot requires more allocations before page_ext is ready, the system
just drops the tags.

Switch this to a dynamic array using kmalloc_array(). We pass
__GFP_NO_OBJ_EXT to safely avoid recursive allocation loops.

To handle concurrent SMP boot expansions without destroying boot
latency, the actual allocation happens outside the array spinlock.
Under extreme SMP contention, it catches stale capacity states
by correctly bounding the allocation size against the current index.

The array gets freed in clear_early_alloc_pfn_tag_refs() once page_ext
takes over.

Remove the old TODO comment.

Signed-off-by: Josh Law <joshlaw48@gmail.com>
---
 lib/alloc_tag.c | 70 ++++++++++++++++++++++++++++++++++---------------
 1 file changed, 49 insertions(+), 21 deletions(-)

diff --git a/lib/alloc_tag.c b/lib/alloc_tag.c
index ed1bdcf1f8ab..761d67784e63 100644
--- a/lib/alloc_tag.c
+++ b/lib/alloc_tag.c
@@ -14,6 +14,7 @@
 #include <linux/string_choices.h>
 #include <linux/vmalloc.h>
 #include <linux/kmemleak.h>
+#include <linux/slab.h>
 
 #define ALLOCINFO_FILE_NAME		"allocinfo"
 #define MODULE_ALLOC_TAG_VMAP_SIZE	(100000UL * sizeof(struct alloc_tag))
@@ -771,33 +772,57 @@ static __init bool need_page_alloc_tagging(void)
  *   - Base allocations independent of CPU count
  *   - Per-CPU allocations (e.g., CPU hotplug callbacks during smp_init,
  *     such as trace ring buffers, scheduler per-cpu data)
- *
- * For simplicity, we fix the size to 8192.
- * If insufficient, a warning will be triggered to alert the user.
- *
- * TODO: Replace fixed-size array with dynamic allocation using
- * a GFP flag similar to ___GFP_NO_OBJ_EXT to avoid recursion.
  */
-#define EARLY_ALLOC_PFN_MAX		8192
-
-static unsigned long early_pfns[EARLY_ALLOC_PFN_MAX] __initdata;
-static atomic_t early_pfn_count __initdata = ATOMIC_INIT(0);
+static unsigned long *early_pfns __initdata;
+static int early_pfn_cap __initdata;
+static int early_pfn_count __initdata;
+static DEFINE_SPINLOCK(early_pfn_lock);
 
 static void __init __alloc_tag_add_early_pfn(unsigned long pfn)
 {
-	int old_idx, new_idx;
+	int idx;
+	unsigned long flags;
+	unsigned long *new_pfns = NULL;
+	int new_cap = 0;
 
-	do {
-		old_idx = atomic_read(&early_pfn_count);
-		if (old_idx >= EARLY_ALLOC_PFN_MAX) {
-			pr_warn_once("Early page allocations before page_ext init exceeded EARLY_ALLOC_PFN_MAX (%d)\n",
-				      EARLY_ALLOC_PFN_MAX);
-			return;
+retry:
+	spin_lock_irqsave(&early_pfn_lock, flags);
+
+	idx = early_pfn_count;
+	if (idx >= early_pfn_cap) {
+		/*
+		 * If we don't have an array, or if extreme contention caused our
+		 * pre-allocated array to already be too small, we must allocate.
+		 */
+		if (!new_pfns || idx >= new_cap) {
+			new_cap = early_pfn_cap ? early_pfn_cap * 2 : 256;
+			if (idx >= new_cap)
+				new_cap = idx + 1; /* Catch extreme stale capacity edge cases */
+
+			spin_unlock_irqrestore(&early_pfn_lock, flags);
+
+			kfree(new_pfns); /* Safely discard stale pre-allocations */
+			new_pfns = kmalloc_array(new_cap, sizeof(unsigned long),
+						 GFP_NOWAIT | __GFP_NOWARN | __GFP_NO_OBJ_EXT);
+			if (!new_pfns) {
+				pr_warn_once("Early page allocations before page_ext init dropped\n");
+				return;
+			}
+			goto retry;
 		}
-		new_idx = old_idx + 1;
-	} while (!atomic_try_cmpxchg(&early_pfn_count, &old_idx, new_idx));
 
-	early_pfns[old_idx] = pfn;
+		if (early_pfns)
+			memcpy(new_pfns, early_pfns, early_pfn_count * sizeof(unsigned long));
+		swap(early_pfns, new_pfns);
+		early_pfn_cap = new_cap;
+	}
+
+	early_pfns[idx] = pfn;
+	early_pfn_count = idx + 1;
+
+	spin_unlock_irqrestore(&early_pfn_lock, flags);
+
+	kfree(new_pfns);
 }
 
 typedef void alloc_tag_add_func(unsigned long pfn);
@@ -829,7 +854,7 @@ static void __init clear_early_alloc_pfn_tag_refs(void)
 	/* Make sure we are not racing with __alloc_tag_add_early_pfn() */
 	synchronize_rcu();
 
-	for (i = 0; i < atomic_read(&early_pfn_count); i++) {
+	for (i = 0; i < early_pfn_count; i++) {
 		unsigned long pfn = early_pfns[i];
 
 		if (pfn_valid(pfn)) {
@@ -861,6 +886,9 @@ static void __init clear_early_alloc_pfn_tag_refs(void)
 		}
 
 	}
+
+	kfree(early_pfns);
+	early_pfns = NULL;
 }
 #else /* !CONFIG_MEM_ALLOC_PROFILING_DEBUG */
 static inline void __init clear_early_alloc_pfn_tag_refs(void) {}
-- 
2.34.1

